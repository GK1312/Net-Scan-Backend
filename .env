# Copy to .env and adjust. All settings use the SCANNER_ prefix; nested settings
# use a double underscore (SCANNER_<group>__<field>).

SCANNER_ENVIRONMENT=development

# --- Database (REQUIRED in production — defaults are local placeholders) ---
# Either set the individual fields...
SCANNER_DATABASE__HOST=89.167.16.30
SCANNER_DATABASE__PORT=5432
SCANNER_DATABASE__USER=GK1312
SCANNER_DATABASE__PASSWORD=Gauravsk@100
SCANNER_DATABASE__DATABASE=postgres
# ...or a full DSN (takes precedence over the fields above):
# SCANNER_DATABASE__DSN=postgresql://user:pass@host:5432/dbname
SCANNER_DATABASE__POOL_SIZE=50

# --- RabbitMQ ---
SCANNER_QUEUE__URL=amqp://guest:guest@localhost:5672/
SCANNER_QUEUE__QUEUE_NAME=scan_queue
SCANNER_QUEUE__PREFETCH_COUNT=3

# --- Worker ---
SCANNER_WORKER__BATCH_SIZE=2000
SCANNER_WORKER__CHUNK_SIZE=1000
SCANNER_WORKER__MAX_CONNECTIONS=25
SCANNER_WORKER__RATE_LIMIT_PER_POD=1000
SCANNER_WORKER__MAX_RETRIES=3
SCANNER_WORKER__THREAD_POOL_SIZE=256
SCANNER_WORKER__SHUTDOWN_GRACE_SECONDS=30.0

# --- Probe timeouts (seconds) ---
SCANNER_TIMEOUTS__PING_TIMEOUT=3.0
SCANNER_TIMEOUTS__TCP_CONNECT_TIMEOUT=2.0

# --- Streaming (SSE) ---
SCANNER_STREAM__HEARTBEAT_SECONDS=15.0
SCANNER_STREAM__PAGE_SIZE=500

# --- Security ---
# Set a non-empty API key to require the X-API-Key header on the API.
SCANNER_SECURITY__API_KEY=
SCANNER_SECURITY__SHORT_CIRCUIT_CONFIDENCE=90.0
# Per-client ingress rate limit (0 disables); burst 0 defaults to the per-minute value.
SCANNER_SECURITY__RATE_LIMIT_PER_MINUTE=120
SCANNER_SECURITY__RATE_LIMIT_BURST=0
